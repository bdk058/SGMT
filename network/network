from network.vision_transformer import ViT

class DVT_V2(nn.Module):
    def __init__(self, config, device='cpu'):
        super(DVT_V2, self).__init__()
        self.config = config
        self.device = device

        # === Step 1: Extract ViT configuration
        vit_config = config['ViT']

        self.image_size = vit_config.get('img_size', 32)
        self.patch_size = vit_config.get('patch_size', 4)
        self.num_classes = vit_config.get('num_classes', 10)
        self.dim = vit_config.get('dim', 192)
        self.depth = vit_config.get('depth', 9)
        self.heads = vit_config.get('heads', 12)
        self.dim_head = vit_config.get('dim_head', 16)
        self.mlp_dim_ratio = vit_config.get('mlp_dim_ratio', 2)
        self.channels = vit_config.get('channels', 3)
        self.dropout = vit_config.get('dropout', 0.)
        self.emb_dropout = vit_config.get('emb_dropout', 0.)

        # === Step 2: Define Shifted Patch Tokenization (dynamic)
        self.to_patch_embedding = ShiftedPatchTokenization(
            in_dim=self.channels,
            dim=self.dim,
            patch_size=self.patch_size,
            exist_class_t=False
        )

        # === Step 3: Define Vision Transformer backbone
# assume vit_config = config['ViT'] already read above
# resolve optional soma fields (allow from vit_config or from top-level network config)
        use_soma = bool(vit_config.get('use_soma', False))
        soma_topk = vit_config.get('soma_topk', None)
        soma_proj_query = bool(vit_config.get('soma_proj_query', True))
        soma_proj_hidden = vit_config.get('soma_proj_hidden', max(16, self.dim // 8))
        soma_temperature = float(vit_config.get('soma_temperature', 1.0))

        self.transformer = ViT(
            image_size=self.image_size,     # ViT unified accepts image_size keyword
            patch_size=self.patch_size,
            num_classes=self.num_classes,
            dim=self.dim,
            depth=self.depth,
            heads=self.heads,
            mlp_dim_ratio=self.mlp_dim_ratio,
            dim_head=self.dim_head,
            channels=self.channels,
            dropout=self.dropout,
            emb_dropout=self.emb_dropout,
            use_soma=use_soma,
            soma_topk=soma_topk,
            soma_proj_query=soma_proj_query,
            soma_proj_hidden=soma_proj_hidden,
            soma_temperature=soma_temperature
        )


        # === Step 4: Device placement
        self.to(self.device)

        print(f"[DVT_V2] Initialized — supports dynamic input size, dim={self.dim}, depth={self.depth}, patch={self.patch_size}")

    def forward(self, x):
        """
        Forward pass (supports variable input sizes)
        --------------------------------------------
        Args:
            x : Tensor [B, C, H, W] — arbitrary spatial resolution
        Returns:
            logits : Tensor [B, num_classes]
        """
        B, C, H, W = x.shape
        tokens = self.to_patch_embedding(x)
        out = self.transformer(tokens, H=H, W=W)
        return out


def instantiate_dnm_safe(dnm_cfg):
    """
    Create DNM while filtering keys that DNM.__init__ does not accept.
    This prevents TypeError when config contains transformer-soma keys like topk/att_temperature.
    """
    # if DNM not defined in current scope, import it safely
    global DNM
    # DNM should be present in this module (defined earlier). If not, import:
    try:
        _ = DNM
    except NameError:
        from network.network import DNM as DNM  # fallback
    sig = inspect.signature(DNM.__init__)
    valid = {k for k in sig.parameters.keys() if k != 'self'}
    filtered = {k: v for k, v in dnm_cfg.items() if k in valid}
    return DNM(**filtered)

class DVT_V4(nn.Module):
    """
    DVT_V4 = DVT_V3 + multiscale (patch sizes base, base*2, base*4)
    - Uses MultiScaleSPT to produce tokens at 3 scales
    - Uses MultiScaleTransformer to process and fuse scales -> produces [B, D] features
    - Head: DNM (safe instantiate) or original mlp head
    """
    def __init__(self, config, device='cpu'):
        super(DVT_V4, self).__init__()
        self.config = config
        self.device = device

        vit_cfg = config.get('ViT', {})
        base_patch = int(vit_cfg.get('patch_size', 4))
        dim = int(vit_cfg.get('dim', 192))
        depth = int(vit_cfg.get('depth', 9))
        heads = int(vit_cfg.get('heads', 12))
        dim_head = int(vit_cfg.get('dim_head', max(16, dim // heads)))
        mlp_dim = int(dim * vit_cfg.get('mlp_dim_ratio', 2))
        channels = int(vit_cfg.get('channels', 3))

        # Multi-scale SPT
        self.to_patch_embedding = MultiScaleSPT(in_dim=channels, dim=dim, base_patch=base_patch, exist_class_t=False)

        # MultiScaleTransformer
        self.multiscale_transformer = MultiScaleTransformer(dim=dim,
                                                            depth=depth,
                                                            heads=heads,
                                                            dim_head=dim_head,
                                                            mlp_dim=mlp_dim,
                                                            use_soma=bool(vit_cfg.get('use_soma', False)),
                                                            soma_topk=vit_cfg.get('soma_topk', None),
                                                            soma_proj_query=vit_cfg.get('soma_proj_query', True),
                                                            soma_proj_hidden=vit_cfg.get('soma_proj_hidden', None),
                                                            soma_temperature=vit_cfg.get('soma_temperature', 1.0))

        # final head: DNM or linear
        mlp_head_type = config.get('mlp_head', 'original')
        if mlp_head_type == 'dnm':
            dnm_cfg = config.get('dnm', {})
            self.head = instantiate_dnm_safe(dnm_cfg)
        else:
            self.head = nn.Sequential(nn.LayerNorm(dim), nn.Linear(dim, vit_cfg.get('num_classes', 10)))

        self.to(device)

    def forward(self, x):
        # input x: [B,C,H,W]
        B, C, H, W = x.shape
        tokens = self.to_patch_embedding(x)                  # dict with 'high','mid','low'
        feat = self.multiscale_transformer(tokens, H=H, W=W) # [B, D]
        out = self.head(feat)                                # if DNM, it will accept [B,D] or expand as needed
        return out


def get_network(cfg):
    """
    Factory function to build the network model based on config['name'].
    This keeps the training/testing pipeline modular and expandable.
    """
    name = cfg['name']

    if name == 'DVT':
        from network.vision_transformer import DVT
        return DVT(cfg['ViT'])

    elif name == 'DVT_V2':
        from network.vision_transformer import DVT_V2
        return DVT_V2(cfg['ViT'])

    elif name == 'DVT_NaViT':
        from network.vision_transformer import DVT_NaViT
        return DVT_NaViT(cfg['ViT'])
    
    elif name == 'DVT_V4':
        from network.network import DVT_V4
        return DVT_V4(cfg)

    else:
        raise ValueError(f"[Error] Unknown network name: {name}")
     
